<%- include('partials/head') %><%- include('partials/navbar') %><main class="container py-4"><div class="row g-4"><div class="col-5 col-md-3 col-lg-2"><img class="img-fluid rounded-4 shadow-sm w-100" src="<%= manga.coverUrl %>" alt="Capa de <%= manga.title %>"></div><div class="col-7 col-md-9 col-lg-10"><div class="d-flex flex-wrap justify-content-between gap-3"><div><h1 class="h2 fw-bold"><%= manga.title %></h1><div class="d-flex flex-wrap gap-2 mb-3"><% (manga.genres||[]).forEach(g=>{ %><span class="badge text-bg-secondary"><%= typeof g==='string'?g:(g.name||g.title) %></span><% }) %><% if(manga.status){ %><span class="badge text-bg-info"><%= manga.status %></span><% } %></div></div><% if(user){ %><button id="favoriteButton" class="btn <%= favorite?'btn-danger':'btn-outline-danger' %>" data-provider="<%= provider %>" data-manga-id="<%= manga.id %>" data-title="<%= manga.title %>" data-cover="<%= manga.coverUrl %>"><i class="bi bi-heart<%= favorite?'-fill':'' %> me-1"></i><span><%= favorite?'Favoritado':'Favoritar' %></span></button><% } %></div><p class="text-secondary"><%= manga.synopsis || metadata?.synopsis || 'Sinopse não informada pela fonte.' %></p>
<% if(metadata){ %>
<div class="card border-0 bg-body-tertiary mt-3"><div class="card-body">
  <div class="d-flex flex-wrap justify-content-between gap-2 align-items-center mb-2">
    <h2 class="h6 mb-0"><i class="bi bi-database me-2"></i>Informações do catálogo</h2>
    <span class="badge text-bg-secondary text-uppercase"><%= metadata.source %></span>
  </div>
  <div class="row g-2 small">
    <% if(metadata.score !== null){ %><div class="col-6 col-md-3"><strong>Nota:</strong> <%= (metadata.score/10).toFixed(1) %>/10</div><% } %>
    <% if(metadata.year){ %><div class="col-6 col-md-3"><strong>Ano:</strong> <%= metadata.year %></div><% } %>
    <% if(metadata.format){ %><div class="col-6 col-md-3"><strong>Formato:</strong> <%= metadata.format %></div><% } %>
    <% if(metadata.chapters){ %><div class="col-6 col-md-3"><strong>Capítulos:</strong> <%= metadata.chapters %></div><% } %>
  </div>
  <% if(metadata.authors?.length){ %><div class="small mt-2"><strong>Autores:</strong> <%= metadata.authors.map(a=>a.name).join(', ') %></div><% } %>
</div></div>
<% } %>
</div></div><hr class="my-4"><div class="d-flex justify-content-between align-items-center mb-3"><div><h2 class="h4 mb-0">Capítulos em português brasileiro</h2><p class="small text-secondary mb-0">Filtro ativo: pt-br</p></div><span class="text-secondary small"><%= manga.chapters.length %> disponíveis</span></div><div class="list-group"><% manga.chapters.forEach(ch=>{ %><a href="/ler/<%= provider %>/<%= encodeURIComponent(manga.id) %>/<%= encodeURIComponent(ch.id) %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3"><span><i class="bi bi-file-earmark-image me-2"></i><%= ch.title %></span><span class="small text-secondary"><%= ch.language ? ch.language.toUpperCase() + ' • ' : '' %><%= ch.publishedAt?new Date(ch.publishedAt).toLocaleDateString('pt-BR'):'' %></span></a><% }) %></div></main><%- include('partials/footer') %>
