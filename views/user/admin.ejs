<%- include('../partials/head') %><%- include('../partials/navbar') %><main class="container py-4"><h1 class="h2 fw-bold mb-4">Administração</h1><div class="table-responsive"><table class="table align-middle"><thead><tr><th>Usuário</th><th>E-mail</th><th>Perfil</th><th>Status</th><th></th></tr></thead><tbody><% users.forEach(x=>{ %><tr><td><%= x.name %></td><td><%= x.email %></td><td><%= x.role %></td><td><span class="badge text-bg-<%= x.approved?'success':'warning' %>"><%= x.approved?'Aprovado':'Pendente' %></span></td><td><% if(!x.approved){ %><form method="post" action="/admin/users/<%= x.id %>/approve"><button class="btn btn-sm btn-success">Aprovar</button></form><% } %></td></tr><% }) %></tbody></table></div></main><%- include('../partials/footer') %>
