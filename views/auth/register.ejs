<%- include('../partials/head') %><%- include('../partials/navbar') %><main class="container py-5"><div class="auth-card card mx-auto"><div class="card-body p-4 p-md-5"><h1 class="h3 fw-bold mb-1">Criar conta</h1><p class="text-secondary mb-4">O acesso é restrito a convidados.</p><% if(typeof error!=='undefined'){ %><div class="alert alert-danger"><%= error %></div><% } %><form method="post" action="/cadastro"><div class="form-floating mb-3"><input class="form-control" id="name" name="name" required minlength="2" placeholder="nome"><label for="name">Nome</label></div><div class="form-floating mb-3"><input class="form-control" type="email" id="email" name="email" required placeholder="email"><label for="email">E-mail</label></div><div class="form-floating mb-3"><input class="form-control" type="password" id="password" name="password" minlength="8" required placeholder="senha"><label for="password">Senha (mínimo 8 caracteres)</label></div><div class="form-floating mb-3"><input class="form-control" id="inviteCode" name="inviteCode" required placeholder="convite"><label for="inviteCode">Código de convite</label></div><button class="btn btn-primary w-100 btn-lg">Cadastrar</button></form></div></div></main><%- include('../partials/footer') %>
