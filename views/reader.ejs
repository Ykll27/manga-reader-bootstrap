<%- include('partials/head') %><nav class="navbar border-bottom sticky-top bg-body"><div class="container-fluid"><a class="btn btn-outline-secondary" href="/manga/<%= provider %>/<%= encodeURIComponent(data.manga.id) %>"><i class="bi bi-arrow-left"></i></a><div class="text-center mx-2 overflow-hidden"><div class="fw-semibold text-truncate"><%= data.manga.title %></div><div class="small text-secondary"><%= data.chapter.title %></div></div><button id="themeButton" class="btn btn-outline-secondary"><i class="bi bi-moon-stars"></i></button></div></nav><main id="reader" class="reader mx-auto" data-provider="<%= provider %>" data-manga-id="<%= data.manga.id %>" data-manga-title="<%= data.manga.title %>" data-cover="<%= data.manga.coverUrl %>" data-chapter-id="<%= data.chapter.id %>" data-chapter-title="<%= data.chapter.title %>"><% data.pages.forEach((page,i)=>{ %><img src="<%= page %>" alt="Página <%= i+1 %>" class="reader-page" loading="<%= i<2?'eager':'lazy' %>"><% }) %></main><div class="reader-controls position-fixed bottom-0 start-50 translate-middle-x mb-3"><div class="btn-group shadow"><% if(data.previousId){ %><a class="btn btn-dark" href="/ler/<%= provider %>/<%= encodeURIComponent(data.manga.id) %>/<%= encodeURIComponent(data.previousId) %>" aria-label="Capítulo anterior"><i class="bi bi-chevron-left"></i></a><% } %><button id="toTop" class="btn btn-primary"><i class="bi bi-arrow-up"></i></button><% if(data.nextId){ %><a class="btn btn-dark" href="/ler/<%= provider %>/<%= encodeURIComponent(data.manga.id) %>/<%= encodeURIComponent(data.nextId) %>" aria-label="Próximo capítulo"><i class="bi bi-chevron-right"></i></a><% } %></div></div><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script><script src="/assets/js/app.js"></script><script src="/assets/js/reader.js"></script></body></html>
