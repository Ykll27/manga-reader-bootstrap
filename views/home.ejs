<%- include('partials/head') %><%- include('partials/navbar') %><main class="container py-4"><section class="p-4 p-md-5 rounded-4 bg-body-tertiary border mb-4 hero-gold"><div class="row align-items-center g-4"><div class="col-lg-7"><span class="badge text-bg-primary mb-3">Leitura privada • PT-BR</span><h1 class="display-6 fw-bold">Mangás em português, com visual preto e dourado.</h1><p class="text-secondary mb-0">Busca filtrada para capítulos em português brasileiro, sem anúncios e sem distrações.</p></div><div class="col-lg-5"><form class="input-group input-group-lg" action="/" method="get"><input class="form-control" name="q" value="<%= query %>" placeholder="Pesquisar obra em português" aria-label="Pesquisar"><button class="btn btn-primary"><i class="bi bi-search"></i></button></form></div></div></section><div class="d-flex justify-content-between align-items-end mb-3"><div><h2 class="h4 mb-1"><%= query ? 'Resultados da busca' : 'Lançamentos recentes em PT-BR' %></h2><p class="small text-secondary mb-0">Fonte ativa: <%= provider %></p></div><span class="badge rounded-pill text-bg-secondary"><%= items.length %> obras</span></div><div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-6 g-3"><% items.forEach(item=>{ %><div class="col"><a class="card manga-card h-100 text-decoration-none" href="/manga/<%= provider %>/<%= encodeURIComponent(item.id) %>"><img src="<%= item.coverUrl %>" class="card-img-top manga-cover" alt="Capa de <%= item.title %>" loading="lazy"><div class="card-body p-3"><h3 class="h6 text-body line-clamp-2"><%= item.title %></h3><p class="small text-secondary mb-0"><%= item.latestChapter || item.status || 'Ver detalhes' %></p></div></a></div><% }) %></div><% if(!items.length){ %><div class="text-center border rounded-4 p-5 text-secondary"><i class="bi bi-search display-5"></i><p class="mt-3 mb-0">Nenhuma obra encontrada.</p></div><% } %></main><%- include('partials/footer') %>
