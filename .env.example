PORT=3000
NODE_ENV=development
SESSION_SECRET=troque-por-uma-chave-longa-e-aleatoria
INVITE_CODE=AMIGOS-2026
REQUIRE_ADMIN_APPROVAL=false
ADMIN_EMAIL=admin@exemplo.com

# Provedor ativo: mangadex, mock ou nexus
MANGA_PROVIDER=mangadex

# MangaDex: leitura real de obras e capítulos em português brasileiro
MANGADEX_API_BASE_URL=https://api.mangadex.org
MANGADEX_UPLOADS_BASE_URL=https://uploads.mangadex.org
MANGADEX_LANGUAGES=pt-br

# Ajuste com os valores oficiais fornecidos pela Nexus.
NEXUS_API_BASE_URL=https://nexustoons.com
NEXUS_API_TOKEN=
# Templates opcionais. Tokens aceitos: {query}, {page}, {id}, {chapterId}
NEXUS_LATEST_PATH=/api/v1/mangas/latest?page={page}
NEXUS_SEARCH_PATH=/api/v1/mangas/search?q={query}&page={page}
NEXUS_DETAILS_PATH=/api/v1/mangas/{id}
NEXUS_CHAPTER_PATH=/api/v1/mangas/{id}/chapters/{chapterId}

# Catálogo/metadados. AniList é o principal; Jikan funciona como fallback.
METADATA_ENABLED=true
ANILIST_API_URL=https://graphql.anilist.co
JIKAN_API_BASE_URL=https://api.jikan.moe
